# name: test/sql/rate_limit_config_basic.test
# description: test basic rate limit configuration operations
# group: [sql]

require rate_limit_fs

# First wrap the fake filesystem so rate limiting can be applied
query I
SELECT rate_limit_fs_wrap('RateLimitFsFakeFileSystem');
----
true

# =============================================================================
# Case-insensitive operation tests
# =============================================================================

# Test uppercase operation is normalized to lowercase
query I
SELECT rate_limit_fs_quota('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'READ', 1000, 'blocking');
----
true

# Verify it's stored as lowercase
query IIIIIII
SELECT * FROM rate_limit_fs_configs() WHERE operation = 'read';
----
RateLimitFileSystem - RateLimitFsFakeFileSystem	NULL	read	1000	blocking	0	-1

# Test mixed case operation
query I
SELECT rate_limit_fs_burst('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'ReAd', 2000);
----
true

# Verify burst was added to existing lowercase entry (UPSERT)
query IIIIIII
SELECT * FROM rate_limit_fs_configs() WHERE operation = 'read';
----
RateLimitFileSystem - RateLimitFsFakeFileSystem	NULL	read	1000	blocking	2000	-1

# Clear for next tests
query I
SELECT rate_limit_fs_clear('*', '*');
----
true

# =============================================================================
# Valid configuration tests
# =============================================================================

# Test setting a quota with blocking mode
query I
SELECT rate_limit_fs_quota('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', 1000000, 'blocking');
----
true

# Test setting a burst
query I
SELECT rate_limit_fs_burst('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', 5000000);
----
true

# Test viewing the config
query IIIIIII
SELECT * FROM rate_limit_fs_configs() WHERE operation = 'read';
----
RateLimitFileSystem - RateLimitFsFakeFileSystem	NULL	read	1000000	blocking	5000000	-1

# Test setting quota with non-blocking mode
query I
SELECT rate_limit_fs_quota('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'write', 500000, 'non_blocking');
----
true

# Test setting quota with alternative mode name (hyphenated)
query I
SELECT rate_limit_fs_quota('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'list', 100, 'non-blocking');
----
true

# Test viewing all configs
query IIIIIII
SELECT * FROM rate_limit_fs_configs() ORDER BY operation;
----
RateLimitFileSystem - RateLimitFsFakeFileSystem	NULL	list	100	non_blocking	0	-1
RateLimitFileSystem - RateLimitFsFakeFileSystem	NULL	read	1000000	blocking	5000000	-1
RateLimitFileSystem - RateLimitFsFakeFileSystem	NULL	write	500000	non_blocking	0	-1

# Cleanup
query I
SELECT rate_limit_fs_clear('*', '*');
----
true

# =============================================================================
# Max requests configuration tests
# =============================================================================

# Test setting max_requests
query I
SELECT rate_limit_fs_max_requests('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', 10);
----
true

# Verify max_requests is visible in configs
query IIIIIII
SELECT * FROM rate_limit_fs_configs() WHERE operation = 'read';
----
RateLimitFileSystem - RateLimitFsFakeFileSystem	NULL	read	0	none	0	10

# Test setting max_requests alongside quota
query I
SELECT rate_limit_fs_quota('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', 1000, 'blocking');
----
true

query IIIIIII
SELECT * FROM rate_limit_fs_configs() WHERE operation = 'read';
----
RateLimitFileSystem - RateLimitFsFakeFileSystem	NULL	read	1000	blocking	0	10

# Test resetting max_requests to unlimited
query I
SELECT rate_limit_fs_max_requests('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', -1);
----
true

query IIIIIII
SELECT * FROM rate_limit_fs_configs() WHERE operation = 'read';
----
RateLimitFileSystem - RateLimitFsFakeFileSystem	NULL	read	1000	blocking	0	-1

# Cleanup
query I
SELECT rate_limit_fs_clear('*', '*');
----
true

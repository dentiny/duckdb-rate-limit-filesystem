# name: test/sql/rate_limit_config_errors.test
# description: test rate limit configuration error cases
# group: [sql]

require rate_limit_fs

# Test error: non-existent filesystem for quota
statement error
SELECT rate_limit_fs_quota('NonExistentFS', 'read', 1000, 'blocking');
----
not found

# Test error: non-existent filesystem for burst
statement error
SELECT rate_limit_fs_burst('NonExistentFS', 'read', 1000);
----
not found

# Wrap the fake filesystem for remaining tests
query I
SELECT rate_limit_fs_wrap('RateLimitFsFakeFileSystem');
----
true

# Test error: invalid operation for quota
statement error
SELECT rate_limit_fs_quota('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'invalid_op', 1000, 'blocking');
----
Invalid operation

# Test error: invalid operation for burst
statement error
SELECT rate_limit_fs_burst('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'unknown', 1000);
----
Invalid operation

# Test error: invalid mode
statement error
SELECT rate_limit_fs_quota('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', 1000, 'invalid_mode');
----
Invalid rate limit mode

# Test error: negative quota
statement error
SELECT rate_limit_fs_quota('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', -100, 'blocking');
----
Quota value must be non-negative

# Test error: negative burst
statement error
SELECT rate_limit_fs_burst('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', -100);
----
Burst value must be non-negative

# Test error: burst on non-byte operations (only READ/WRITE support burst)
statement error
SELECT rate_limit_fs_burst('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'stat', 100);
----
Burst limit can only be set for READ or WRITE operations

statement error
SELECT rate_limit_fs_burst('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'list', 100);
----
Burst limit can only be set for READ or WRITE operations

statement error
SELECT rate_limit_fs_burst('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'delete', 100);
----
Burst limit can only be set for READ or WRITE operations

statement error
SELECT rate_limit_fs_burst('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'mkdir', 100);
----
Burst limit can only be set for READ or WRITE operations

# Test error: max_requests with value 0
statement error
SELECT rate_limit_fs_max_requests('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', 0);
----
Max requests value cannot be 0

# Test error: max_requests with value < -1
statement error
SELECT rate_limit_fs_max_requests('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'read', -2);
----
Max requests value must be -1 (unlimited) or a positive integer

# Test error: max_requests on non-existent filesystem
statement error
SELECT rate_limit_fs_max_requests('NonExistentFS', 'read', 5);
----
not found

# Test error: max_requests with invalid operation
statement error
SELECT rate_limit_fs_max_requests('RateLimitFileSystem - RateLimitFsFakeFileSystem', 'invalid_op', 5);
----
Invalid operation
